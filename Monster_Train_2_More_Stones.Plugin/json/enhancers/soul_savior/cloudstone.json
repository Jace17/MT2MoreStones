{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_UnitUpgradeShift",
      "type": "enhancer",
      "names": {
        "english": "Cloudslab",
        "chinese": "腾云石"
      },
      "descriptions": {
        "english": "Upgrade a unit with '[shift]: +[effect0.upgrade.charactertrigger0.effect0.upgrade.bonusdamage][attack] and [armor] [effect0.upgrade.charactertrigger0.effect0.upgrade.status0.power].'",
        "chinese": "升级一个单位，使其获得'[shift]：+[effect0.upgrade.charactertrigger0.effect0.upgrade.bonusdamage][attack]，+[effect0.upgrade.charactertrigger0.effect0.upgrade.bonushp][health]。'"
      },
      "relic_effects": [
        "@SoulSavior_ShiftEnhancer"
      ],
      "icon": "@SoulSavior_CloudstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassBanished",
            "pools": [
              "SoulSavior_UnitUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_ShiftEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "monster",
      "param_upgrade": "@SoulSavior_AddShift"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddShift",
      "titles": {
        "english": "Cloudslab",
        "chinese": "腾云石"
      },
      "descriptions": {
        "english": "Gain '[shift]: +[charactertrigger0.effect0.upgrade.bonusdamage][attack] and [armor] [charactertrigger0.effect0.upgrade.status0.power].'",
        "chinese": "获得'[shift]：+[charactertrigger0.effect0.upgrade.bonusdamage][attack]，+[charactertrigger0.effect0.upgrade.bonushp][health]。'"
      },
      "icon": "@SoulSavior_CloudstoneIcon",
      "trigger_upgrades": [
        {
          "id": "@SoulSavior_ShiftAdd2Attack2HealthTrigger"
        }
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_CloudstoneIcon",
      "path": "textures/cloudstone.png"
    }
  ],
  "character_triggers": [
    {
      "id": "SoulSavior_ShiftAdd2Attack2HealthTrigger",
      "trigger": "on_shift",
      "descriptions": {
        "english": "+[effect0.upgrade.bonusdamage][attack] and [armor] [effect0.upgrade.status0.power].",
        "chinese": "+[effect0.upgrade.bonusdamage][attack]，+[effect0.upgrade.bonushp][health]。"
      },
      "effects": [
        {
          "id": "@EffectAdd4Attack4Armor"
        }
      ]
    }
  ]
}