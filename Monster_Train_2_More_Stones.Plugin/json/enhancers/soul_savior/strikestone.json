{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_UnitUpgradeStrike",
      "type": "enhancer",
      "names": {
        "english": "Strikeslab"
      },
      "descriptions": {
        "english": "Upgrade a unit with '[strike]: +[effect0.upgrade.charactertrigger0.effect0.upgrade.bonusdamage][attack] and [armor] [effect0.upgrade.charactertrigger0.effect0.upgrade.status0.power].'"
      },
      "relic_effects": [
        "@SoulSavior_StrikeEnhancer"
      ],
      "icon": "@SoulSavior_StrikestoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassHellhorned",
            "pools": [
              "SoulSavior_UnitUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_StrikeEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "monster",
      "param_upgrade": "@SoulSavior_AddStrike"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddStrike",
      "titles": {
        "english": "Strikeslab"
      },
      "descriptions": {
        "english": "Gain '[strike]: +[charactertrigger0.effect0.upgrade.bonusdamage][attack] and [armor] [charactertrigger0.effect0.upgrade.status0.power].'"
      },
      "icon": "@SoulSavior_StrikestoneIcon",
      "trigger_upgrades": [
        {
          "id": "@SoulSavior_StrikeAdd4Attack4ArmorTrigger"
        }
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_StrikestoneIcon",
      "path": "textures/strikestone.png"
    }
  ],
  "character_triggers": [
    {
      "id": "SoulSavior_StrikeAdd4Attack4ArmorTrigger",
      "trigger": "on_attacking",
      "descriptions": {
        "english": "+[effect0.upgrade.bonusdamage][attack] and [armor] [effect0.upgrade.status0.power]."
      },
      "effects": [
        {
          "id": "@EffectAdd8Attack8Armor"
        }
      ]
    }
  ]
}