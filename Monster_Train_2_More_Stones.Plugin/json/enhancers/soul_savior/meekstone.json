{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeSap",
      "type": "enhancer",
      "names": {
        "english": "Meekstone+",
        "chinese": "驯化石"
      },
      "descriptions": {
        "english": "Upgrade a spell to apply [sap] [effect0.upgrade.trigger0.effect0.status0.power] to enemy units.",
        "chinese": "升级一个法术，使其获得'对本层所有敌方单位施加[sap] [effect0.upgrade.trigger0.effect0.status0.power]。'"
      },
      "relic_effects": [
        "@SoulSavior_SapEnhancer"
      ],
      "icon": "@SoulSavior_MeekstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassStygian",
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_SapEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddSapEffect"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddSapEffect",
      "titles": {
        "english": "Meekstone+",
        "chinese": "驯化石"
      },
      "descriptions": {
        "english": "Gain 'Apply [sap] [trigger0.effect0.status0.power] to enemy units.'",
        "chinese": "获得'对本层所有敌方单位施加[sap] [trigger0.effect0.status0.power]。'"
      },
      "icon": "@SoulSavior_MeekstoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_ApplySapTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_MeekstoneIcon",
      "path": "textures/meekstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_ApplySapTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "Apply [sap] [effect0.status0.power] to enemy units.",
        "chinese": "对本层所有敌方单位施加[sap] [effect0.status0.power]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_EffectApplySap"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_EffectApplySap",
      "name": "CardEffectAddStatusEffect",
      "target_mode": "room",
      "target_team": "heroes",
      "param_status_effects": [
        {
          "status": "debuff",
          "count": 4
        }
      ]
    }
  ]
}