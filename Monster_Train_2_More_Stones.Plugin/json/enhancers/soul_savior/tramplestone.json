{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_UnitUpgradeTrample",
      "type": "enhancer",
      "names": {
        "english": "Stompstone",
        "chinese": "蹂躏石"
      },
      "descriptions": {
        "english": "Upgrade a unit with [trample].",
        "chinese": "升级一个单位，使其获得[trample]。"
      },
      "relic_effects": [
        "@SoulSavior_TrampleEnhancer"
      ],
      "icon": "@SoulSavior_TramplestoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": null,
            "pools": [
              "SoulSavior_UnitUpgradePoolRare",
              "DraftUpgradePool",
              "MalickaDraftUpgradePool"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_TrampleEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "monster",
      "param_upgrade": "@SoulSavior_AddTrample"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddTrample",
      "titles": {
        "english": "Stompstone",
        "chinese": "蹂躏石"
      },
      "descriptions": {
        "english": "Gain [trample].",
        "chinese": "获得[trample]。"
      },
      "icon": "@SoulSavior_TramplestoneIcon",
      "status_effect_upgrades": [
        {
          "status": "trample",
          "count": 1
        }
      ],
      "filters": [
        "ExcludeEelGorgon",
        "@SoulSavior_ExcludeTrample"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_TramplestoneIcon",
      "path": "textures/tramplestone-v2.png"
    }
  ],
  "upgrade_masks": [
    {
      "id": "SoulSavior_ExcludeTrample",
      "excluded_status": [
        {
          "status": "trample",
          "count": 1
        }
      ]
    }
  ]
}