{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeGainSmelt",
      "type": "enhancer",
      "names": {
        "english": "Smeltstone+",
        "chinese": "熔炼石"
      },
      "descriptions": {
        "english": "Upgrade a spell to add 'Draw [effect0.upgrade.trigger0.effect0.paramint]. [smelt] a card in hand.'",
        "chinese": "升级一个法术，使其获得'[smelt]一张手牌。'"
      },
      "relic_effects": [
        "@SoulSavior_GainSmeltEnhancer"
      ],
      "icon": "@SoulSavior_SmeltstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassRailforged",
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_GainSmeltEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_GainSmelt"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_GainSmelt",
      "titles": {
        "english": "Smeltstone+",
        "chinese": "熔炼石"
      },
      "descriptions": {
        "english": "Gain 'Draw [trigger0.effect0.paramint]. [smelt] a card in hand.'",
        "chinese": "获得'[smelt]一张手牌。'"
      },
      "icon": "@SoulSavior_SmeltstoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_GainSmeltTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_SmeltstoneIcon",
      "path": "textures/smeltstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_GainSmeltTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "Draw [effect0.paramint]. [smelt] a card in hand.",
        "chinese": "[smelt]一张手牌。"
      },
      "effects": [
        {
          "id": "@SoulSavior_GainDrawEffect"
        },
        {
          "id": "@SoulSavior_GainSmeltEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_GainDrawEffect",
      "name": "CardEffectDraw",
      "param_int": 1
    },
    {
      "id": "SoulSavior_GainSmeltEffect",
      "name": "CardEffectChooseDiscard",
      "target_mode": "hand",
      "param_int": 3,
      "param_int_2": 5,
      "param_bool_2": true
    }
  ]
}