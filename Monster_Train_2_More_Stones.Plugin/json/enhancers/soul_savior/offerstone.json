{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeOffering",
      "type": "enhancer",
      "names": {
        "english": "Offerstone+",
        "chinese": "献祭石+"
      },
      "descriptions": {
        "english": "Upgrade a targetless spell to gain <b>Offering</b> and -[effect0.upgrade.costreduction][ember].",
        "chinese": "升级一个非指定目标法术，使其获得<b>献祭</b>，费用 -[effect0.upgrade.costreduction][ember]。"
      },
      "relic_effects": [
        "@SoulSavior_OfferingEnhancer"
      ],
      "icon": "@SoulSavior_OfferstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassStygian",
            "pools": [
              "SoulSavior_SpellUpgradePoolCostReduction"
            ],
            "rarity": "common"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_OfferingEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddOfferingTrait"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddOfferingTrait",
      "titles": {
        "english": "Offerstone+",
        "chinese": "献祭石+"
      },
      "descriptions": {
        "english": "Gain <b>Offering</b> and -[costreduction][ember].",
        "chinese": "获得<b>献祭</b>，费用 -[costreduction][ember]。"
      },
      "icon": "@SoulSavior_OfferstoneIcon",
      "cost_reduction": 2,
      "x_cost_reduction": 2,
      "trait_upgrades": [
        {
          "id": "@SoulSavior_OfferingTrait"
        }
      ],
      "filters": [
        "OnlySpells",
        "@SoulSavior_TargetlessOnly",
        "@SoulSavior_ExcludeOffering"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_OfferstoneIcon",
      "path": "textures/offerstone.png"
    }
  ],
  "upgrade_masks": [
    {
      "id": "SoulSavior_ExcludeOffering",
      "excluded_traits": [
        "CardTraitTreasure"
      ]
    },
    {
      "id": "SoulSavior_TargetlessOnly",
      "card_target_mode": [ "targetless" ]
    }
  ],
  "traits": [
    {
      "id": "SoulSavior_OfferingTrait",
      "name": "CardTraitTreasure"
    }
  ]
}