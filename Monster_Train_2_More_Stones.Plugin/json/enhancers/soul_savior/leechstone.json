    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddLifesteal",
      "titles": {
        "english": "Leechslab",
        "chinese": "水蛭石"
      },
      "descriptions": {
        "english": "Gain [lifesteal] [status0.power] and +[bonusdamage][attack].",
        "chinese": "获得[lifesteal] [status0.power]，+[bonusdamage][attack]。"
