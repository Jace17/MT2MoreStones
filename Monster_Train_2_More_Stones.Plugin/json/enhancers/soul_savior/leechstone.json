{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_UnitUpgradeLifesteal",
      "type": "enhancer",
      "names": {
        "english": "Leechslab",
        "chinese": "水蛭石"
      },
      "descriptions": {
        "english": "Upgrade a unit with [lifesteal] [effect0.upgrade.status0.power] and +[effect0.upgrade.bonusdamage][attack].",
        "chinese": "升级一个单位，使其获得[lifesteal] [effect0.upgrade.status0.power]，+[effect0.upgrade.bonusdamage][attack]。"
      },
      "relic_effects": [
        "@SoulSavior_LifestealEnhancer"
      ],
      "icon": "@SoulSavior_LeechstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassUmbra",
            "pools": [
              "SoulSavior_UnitUpgradePoolCommon",
              "DraftUpgradePool",
              "MalickaDraftUpgradePool"
            ],
              "rarity": "common"
          }
        }
      ]
