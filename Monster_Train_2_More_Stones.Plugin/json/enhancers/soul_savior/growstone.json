{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradePropagate",
      "type": "enhancer",
      "names": {
        "english": "Growstone",
        "chinese": "生长石"
      },
      "descriptions": {
        "english": "Upgrade a spell to add '[propagate] [effect0.upgrade.trigger0.effect0.paramint] on all units.'",
        "chinese": "升级一个法术，使其获得'使本层所有单位[propagate] [effect0.upgrade.trigger0.effect0.paramint]。'"
      },
      "relic_effects": [
        "@SoulSavior_AddPropagateEnhancer"
      ],
      "icon": "@SoulSavior_GrowstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassUnderlegion",
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon",
              "DraftUpgradePool",
              "MalickaDraftUpgradePool"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_AddPropagateEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddPropagate"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddPropagate",
      "titles": {
        "english": "Growstone",
        "chinese": "生长石"
      },
      "descriptions": {
        "english": "Gain '[propagate] [trigger0.effect0.paramint] on all units.'",
        "chinese": "获得'使本层所有单位[propagate] [trigger0.effect0.paramint]。'"
      },
      "icon": "@SoulSavior_GrowstoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_AddPropagateTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_GrowstoneIcon",
      "path": "textures/growstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_AddPropagateTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "[propagate] [effect0.paramint] on all units.",
        "chinese": "使本层所有单位[propagate] [effect0.paramint]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_PropagateEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_PropagateEffect",
      "name": "CardEffectAdjustAllStatusEffects",
      "target_mode": "room",
      "target_team": "both",
      "param_int": 1,
      "param_int_2": 1
    }
  ]
}