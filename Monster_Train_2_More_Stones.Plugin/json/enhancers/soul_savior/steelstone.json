{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_UnitUpgradeAddSteelguard",
      "type": "enhancer",
      "names": {
        "english": "Steelslab",
        "chinese": "钢铁石板"
      },
      "descriptions": {
        "english": "Upgrade a unit with [steelguard] and [armor] [effect0.upgrade.status0.power].",
        "chinese": "升级一个单位，使其获得[armor] [effect0.upgrade.status0.power] 和[steelguard]。"
      },
      "relic_effects": [
        "@SoulSavior_AddSteelguardEnhancer"
      ],
      "icon": "@SoulSavior_SteelstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassRailforged",
            "pools": [
              "SoulSavior_UnitUpgradePoolRare"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_AddSteelguardEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "monster",
      "param_upgrade": "@SoulSavior_AddSteelguard"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddSteelguard",
      "titles": {
        "english": "Steelslab",
        "chinese": "钢铁石板"
      },
      "descriptions": {
        "english": "Gain [steelguard] and [armor] [status0.power].",
        "chinese": "获得[armor] [status0.power] 和[steelguard]。"
      },
      "icon": "@SoulSavior_SteelstoneIcon",
      "status_effect_upgrades": [
        {
          "status": "armor",
          "count": 75
        },
        {
          "status": "steelguard",
          "count": 1
        }
      ],
      "filters": [
        "ExcludeEelGorgon",
        "@SoulSavior_ExcludeSteelguard"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_SteelstoneIcon",
      "path": "textures/steelstone.png"
    }
  ],
  "upgrade_masks": [
    {
      "id": "SoulSavior_ExcludeSteelguard",
      "excluded_status": [
        {
          "status": "steelguard",
          "count": 1
        }
      ]
    }
  ],
  "traits": [
    {
      "id": "SoulSavior_SteelguardTrait",
      "name": "CardTraitModifyArmorOnHit",
      "param_int": 15
    }
  ]
}