{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeAttuned",
      "type": "enhancer",
      "names": {
        "english": "Tunestone",
        "chinese": "调音石"
      },
      "descriptions": {
        "english": "Upgrade a spell to gain [attuned].",
        "chinese": "升级一个法术，使其获得[attuned]。"
      },
      "relic_effects": [
        "@SoulSavior_AttunedEnhancer"
      ],
      "icon": "@SoulSavior_AttunestoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": null,
            "pools": [
              "SpellUpgradePoolRare",
              "DraftUpgradePool",
              "MalickaDraftUpgradePool"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_AttunedEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddAttunedTrait"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddAttunedTrait",
      "titles": {
        "english": "Tunestone",
        "chinese": "调音石"
      },
      "descriptions": {
        "english": "Gain [attuned].",
        "chinese": "获得[attuned]。"
      },
      "icon": "@SoulSavior_AttunestoneIcon",
      "trait_upgrades": [
        {
          "id": "@SoulSavior_AttunedTrait"
        }
      ],
      "filters": [
        "MagicPowerSpells",
        "@SoulSavior_ExcludeAttuned"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_AttunestoneIcon",
      "path": "textures/attunestone.png"
    }
  ],
  "upgrade_masks": [
    {
      "id": "SoulSavior_ExcludeAttuned",
      "excluded_traits": [
        "CardTraitStrongerMagicPower"
      ]
    }
  ],
  "traits": [
    {
      "id": "SoulSavior_AttunedTrait",
      "name": "CardTraitStrongerMagicPower"
    }
  ]
}