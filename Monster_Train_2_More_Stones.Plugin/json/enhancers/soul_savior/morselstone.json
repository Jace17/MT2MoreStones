{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeAddMorsel",
      "type": "enhancer",
      "names": {
        "english": "Morselstone",
        "chinese": "影裔石"
      },
      "descriptions": {
        "english": "Upgrade a spell to add 'Add a common or uncommon [snack] unit to your hand.'",
        "chinese": "升级一个法术，使其获得'将一个普通或高级[snack]单位加入你的手牌。'"
      },
      "relic_effects": [
        "@SoulSavior_AddMorselEnhancer"
      ],
      "icon": "@SoulSavior_MorselstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassUmbra",
            "pools": [
              "SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_AddMorselEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddMorselToHand"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddMorselToHand",
      "titles": {
        "english": "Morselstone",
        "chinese": "影裔石"
      },
      "descriptions": {
        "english": "Gain 'Add a common or uncommon [snack] unit to your hand.'",
        "chinese": "获得'将一个普通或高级[snack]单位加入你的手牌。'"
      },
      "icon": "@SoulSavior_MorselstoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_AddMorselToHandTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_MorselstoneIcon",
      "path": "textures/morselstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_AddMorselToHandTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "Add a common or uncommon [snack] unit to your hand.",
        "chinese": "将一个普通或高级[snack]单位加入你的手牌。"
      },
      "effects": [
        {
          "id": "@SoulSavior_AddMorselToHandEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_AddMorselToHandEffect",
      "name": "CardEffectAddBattleCard",
      "param_int": 3,
      "param_card_pool": "@SoulSavior_RandomMorselCardPool"
    }
  ],
  "card_pools": [
    {
      "id": "SoulSavior_RandomMorselCardPool",
      "cards": [
        "VoidExcavator",
        "ShadowMorsel",
        "MoltenMorsel",
        "MorselJeweler",
        "RubbleRaiser",
        "RubbleRaiser",
        "RubbleRaiser",
        "RubbleRaiser"
      ]
    }
  ]
}