{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeRetreat",
      "type": "enhancer",
      "names": {
        "english": "Backstone+",
        "chinese": "后移石+"
      },
      "descriptions": {
        "english": "Upgrade a targeted spell to add [retreat] and -[effect0.upgrade.costreduction][ember].",
        "chinese": "升级一个指定目标法术，使其获得'[retreat]'，费用 -[effect0.upgrade.costreduction][ember]。"
      },
      "relic_effects": [
        "@SoulSavior_RetreatEnhancer"
      ],
      "icon": "@SoulSavior_BackstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": null,
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_RetreatEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddRetreat"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddRetreat",
      "titles": {
        "english": "Backstone+",
        "chinese": "后移石+"
      },
      "descriptions": {
        "english": "Gain [retreat] and -[costreduction][ember].",
        "chinese": "获得'[retreat]'，费用 -[costreduction][ember]。"
      },
      "icon": "@SoulSavior_BackstoneIcon",
      "cost_reduction": 1,
      "x_cost_reduction": 1,
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_RetreatTrigger"
        }
      ],
      "filters": [
        "OnlySpells",
        "@SingleTargetOnly",
        "@NoAdvanceOrRetreat"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_BackstoneIcon",
      "path": "textures/backstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_RetreatTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "[retreat].",
        "chinese": "[retreat]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_RetreatEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_RetreatEffect",
      "name": "CardEffectFloorRearrange",
      "target_mode": "last_targeted_characters",
      "param_int": 1
    }
  ]
}