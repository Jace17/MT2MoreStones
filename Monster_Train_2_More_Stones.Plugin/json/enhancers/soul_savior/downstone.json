{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeDescend",
      "type": "enhancer",
      "names": {
        "english": "Downstone+",
        "chinese": "下移石"
      },
      "descriptions": {
        "english": "Upgrade a targeted spell to add [descend] and -[effect0.upgrade.costreduction][ember].",
        "chinese": "升级一个指定目标法术，使其获得'[descend]。'"
      },
      "relic_effects": [
        "@SoulSavior_DescendEnhancer"
      ],
      "icon": "@SoulSavior_DownstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": null,
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_DescendEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddDescend"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddDescend",
      "titles": {
        "english": "Downstone+",
        "chinese": "下移石"
      },
      "descriptions": {
        "english": "Gain [descend] and -[costreduction][ember].",
        "chinese": "获得'[descend]。'"
      },
      "icon": "@SoulSavior_DownstoneIcon",
      "cost_reduction": 1,
      "x_cost_reduction": 1,
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_DescendTrigger"
        }
      ],
      "filters": [
        "OnlySpells",
        "@SingleTargetOnly",
        "@NoAscendOrDescend"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_DownstoneIcon",
      "path": "textures/downstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_DescendTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "[descend].",
        "chinese": "[descend]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_DescendEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_DescendEffect",
      "name": "CardEffectBump",
      "target_mode": "last_targeted_characters",
      "param_int": -1
    }
  ]
}