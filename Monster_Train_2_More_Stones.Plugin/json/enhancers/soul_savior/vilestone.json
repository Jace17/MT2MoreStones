{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeCorruption",
      "type": "enhancer",
      "names": {
        "english": "Vilestone+",
        "chinese": "腐败石"
      },
      "descriptions": {
        "english": "Upgrade a spell to apply [corruption] [effect0.upgrade.trigger0.effect0.status0.power] to enemy units.",
        "chinese": "升级一个法术，使其获得'对本层所有敌方单位施加[corruption] [effect0.upgrade.trigger0.effect0.status0.power]。'"
      },
      "relic_effects": [
        "@SoulSavior_CorruptionEnhancer"
      ],
      "icon": "@SoulSavior_VilestoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": null,
            "pools": [
              "SoulSavior_SpellUpgradePoolRare"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_CorruptionEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddCorruptionEffect"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddCorruptionEffect",
      "titles": {
        "english": "Vilestone+",
        "chinese": "腐败石"
      },
      "descriptions": {
        "english": "Gain 'Apply [corruption] [trigger0.effect0.status0.power] to enemy units.'",
        "chinese": "获得'对本层所有敌方单位施加[corruption] [trigger0.effect0.status0.power]。'"
      },
      "icon": "@SoulSavior_VilestoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_ApplyCorruptionTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_VilestoneIcon",
      "path": "textures/vilestone-v2.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_ApplyCorruptionTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "Apply [corruption] [effect0.status0.power] to enemy units.",
        "chinese": "对本层所有敌方单位施加[corruption] [effect0.status0.power]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_EffectApplyCorruption"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_EffectApplyCorruption",
      "name": "CardEffectAddStatusEffect",
      "target_mode": "room",
      "target_team": "heroes",
      "param_status_effects": [
        {
          "status": "corruption",
          "count": 40
        }
      ]
    }
  ]
}