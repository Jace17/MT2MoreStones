{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeMix",
      "type": "enhancer",
      "names": {
        "english": "Flaskstone+",
        "chinese": "试剂石+"
      },
      "descriptions": {
        "english": "Upgrade a spell to add '[mix] twice.'",
        "chinese": "升级一个法术，使其获得'[mix]两次。'"
      },
      "relic_effects": [
        "@SoulSavior_AddMixEnhancer"
      ],
      "icon": "@SoulSavior_FlaskstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassLazarusLeague",
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_AddMixEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddMix"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddMix",
      "titles": {
        "english": "Flaskstone+",
        "chinese": "试剂石+"
      },
      "descriptions": {
        "english": "Gain '[mix] twice.'",
        "chinese": "获得'[mix]两次。'"
      },
      "icon": "@SoulSavior_FlaskstoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_AddMixTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_FlaskstoneIcon",
      "path": "textures/flaskstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_AddMixTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "[mix] twice.",
        "chinese": "[mix]两次。"
      },
      "effects": [
        {
          "id": "@SoulSavior_MixEffect"
        },
        {
          "id": "@SoulSavior_MixEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_MixEffect",
      "name": "CardEffectMix",
      "param_int": 2
    }
  ]
}