{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeAscend",
      "type": "enhancer",
      "names": {
        "english": "Upstone+",
        "chinese": "上移石"
      },
      "descriptions": {
        "english": "Upgrade a targeted spell to add [ascend] and -[effect0.upgrade.costreduction][ember].",
        "chinese": "升级一个指定目标法术，使其获得'[ascend]。'"
      },
      "relic_effects": [
        "@SoulSavior_AscendEnhancer"
      ],
      "icon": "@SoulSavior_UpstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": null,
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_AscendEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddAscend"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddAscend",
      "titles": {
        "english": "Upstone+",
        "chinese": "上移石"
      },
      "descriptions": {
        "english": "Gain [ascend] and -[costreduction][ember].",
        "chinese": "获得'[ascend]。'"
      },
      "icon": "@SoulSavior_UpstoneIcon",
      "cost_reduction": 1,
      "x_cost_reduction": 1,
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_AscendTrigger"
        }
      ],
      "filters": [
        "OnlySpells",
        "@SingleTargetOnly",
        "@NoAscendOrDescend"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_UpstoneIcon",
      "path": "textures/upstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_AscendTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "[ascend].",
        "chinese": "[ascend]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_AscendEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_AscendEffect",
      "name": "CardEffectBump",
      "target_mode": "last_targeted_characters",
      "param_int": 1
    }
  ]
}