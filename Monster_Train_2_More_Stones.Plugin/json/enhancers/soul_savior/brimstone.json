    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddDamageAll",
      "titles": {
        "english": "Brimstone+",
        "chinese": "硫黄石"
      },
      "descriptions": {
        "english": "Gain 'Deal [trigger0.effect0.power] damage to enemy units.'",
