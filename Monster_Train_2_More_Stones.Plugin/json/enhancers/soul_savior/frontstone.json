{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeAdvance",
      "type": "enhancer",
      "names": {
        "english": "Frontstone+",
        "chinese": "前移石"
      },
      "descriptions": {
        "english": "Upgrade a targeted spell to add [advance] and -[effect0.upgrade.costreduction][ember].",
        "chinese": "升级一个指定目标法术，使其获得'[advance]。'"
      },
      "relic_effects": [
        "@SoulSavior_AdvanceEnhancer"
      ],
      "icon": "@SoulSavior_FrontstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": null,
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_AdvanceEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddAdvance"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddAdvance",
      "titles": {
        "english": "Frontstone+",
        "chinese": "前移石"
      },
      "descriptions": {
        "english": "Gain [advance] and -[effect0.upgrade.costreduction][ember].",
        "chinese": "获得'[advance]。'"
      },
      "icon": "@SoulSavior_FrontstoneIcon",
      "cost_reduction": 1,
      "x_cost_reduction": 1,
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_AdvanceTrigger"
        }
      ],
      "filters": [
        "OnlySpells",
        "@SingleTargetOnly",
        "@NoAdvanceOrRetreat"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_FrontstoneIcon",
      "path": "textures/frontstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_AdvanceTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "[advance].",
        "chinese": "[advance]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_AdvanceEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_AdvanceEffect",
      "name": "CardEffectFloorRearrange",
      "target_mode": "last_targeted_characters",
      "param_int": 0
    }
  ]
}