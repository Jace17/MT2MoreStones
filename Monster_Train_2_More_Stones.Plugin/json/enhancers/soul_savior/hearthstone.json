{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeRefine",
      "type": "enhancer",
      "names": {
        "english": "Hearthstone",
        "chinese": "炉底石"
      },
      "descriptions": {
        "english": "Upgrade a spell to add [refined] [effect0.upgrade.trait0.paramint].",
        "chinese": "升级一个法术，使其获得[refined] [effect0.upgrade.trait0.paramint]。"
      },
      "relic_effects": [
        "@SoulSavior_RefineEnhancer"
      ],
      "icon": "@SoulSavior_HearthstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassRailforged",
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "common"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_RefineEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddRefineTrait"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddRefineTrait",
      "titles": {
        "english": "Hearthstone",
        "chinese": "炉底石"
      },
      "descriptions": {
        "english": "Gain [refined] [trait0.paramint].",
        "chinese": "获得[refined] [trait0.paramint]。"
      },
      "icon": "@SoulSavior_HearthstoneIcon",
      "trait_upgrades": [
        {
          "id": "@SoulSavior_RefineTrait"
        }
      ],
      "filters": [
        "@SoulSavior_ExcludeRefine"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_HearthstoneIcon",
      "path": "textures/hearthstone.png"
    }
  ],
  "upgrade_masks": [
    {
      "id": "SoulSavior_ExcludeRefine",
      "excluded_traits": [
        "CardTraitRefine"
      ]
    }
  ],
  "traits": [
    {
      "id": "SoulSavior_RefineTrait",
      "name": "CardTraitRefine",
      "param_int": 3
    }
  ]
}