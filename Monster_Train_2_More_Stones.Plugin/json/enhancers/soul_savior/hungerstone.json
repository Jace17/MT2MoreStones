{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_UnitUpgradeHunger",
      "type": "enhancer",
      "names": {
        "english": "Hungerslab"
      },
      "descriptions": {
        "english": "Upgrade a unit with '<b>Hunger</b>: Feed on units with [eaten].' and +[effect0.upgrade.bonushp][health]."
      },
      "relic_effects": [
        "@SoulSavior_HungerEnhancer"
      ],
      "icon": "@SoulSavior_HungerstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassUmbra",
            "pools": [
              "SoulSavior_UnitUpgradePoolRare"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_HungerEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "monster",
      "param_upgrade": "@SoulSavior_AddHunger"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddHunger",
      "titles": {
        "english": "Hungerslab"
      },
      "descriptions": {
        "english": "Gain '<b>Hunger</b>: Feed on units with [eaten].' and +[bonushp][health]."
      },
      "icon": "@SoulSavior_HungerstoneIcon",
      "bonus_hp": 30,
      "trigger_upgrades": [
        {
          "id": "@SoulSavior_HungerEatFood"
        }
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_HungerstoneIcon",
      "path": "textures/hungerstone.png"
    }
  ],
  "character_triggers": [
    {
      "id": "SoulSavior_HungerEatFood",
      "trigger": "on_food_spawn",
      "descriptions": {
        "english": "Feed on units with [eaten]."
      },
      "effects": [
        {
          "id": "@SoulSavior_EffectEatFood"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_EffectEatFood",
      "name": "CardEffectFeederRules",
      "target_mode": "room",
      "target_team": "monsters",
      "param_bool": true
    }
  ]
}