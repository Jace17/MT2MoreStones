{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeAddImp",
      "type": "enhancer",
      "names": {
        "english": "Impstone",
        "chinese": "碎尾石"
      },
      "descriptions": {
        "english": "Upgrade a spell to add 'Add a common or uncommon [imp] unit to your hand.'",
        "chinese": "升级一个法术，使其获得'将一个普通或高级[imp]单位加入你的手牌。'"
      },
      "relic_effects": [
        "@SoulSavior_AddImpEnhancer"
      ],
      "icon": "@SoulSavior_ImpstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassHellhorned",
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_AddImpEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddImpToHand"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddImpToHand",
      "titles": {
        "english": "Impstone",
        "chinese": "碎尾石"
      },
      "descriptions": {
        "english": "Gain 'Add a common or uncommon [imp] unit to your hand.'",
        "chinese": "获得'将一个普通或高级[imp]单位加入你的手牌。'"
      },
      "icon": "@SoulSavior_ImpstoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_AddImpToHandTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_ImpstoneIcon",
      "path": "textures/impstone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_AddImpToHandTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "Add a common or uncommon [imp] unit to your hand.",
        "chinese": "将一个普通或高级[imp]单位加入你的手牌。"
      },
      "effects": [
        {
          "id": "@SoulSavior_AddImpToHandEffect"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_AddImpToHandEffect",
      "name": "CardEffectAddBattleCard",
      "param_int": 3,
      "param_card_pool": "@SoulSavior_RandomImpCardPool"
    }
  ],
  "card_pools": [
    {
      "id": "SoulSavior_RandomImpCardPool",
      "cards": [
        "AggressiveImp",
        "AggressiveImp",
        "StarterImp",
        "StarterImp",
        "UnstableInfery",
        "UnstableInfery",
        "WelderHelper",
        "WelderHelper",
        "EmberedInfery",
        "EnlightenedInfery"
      ]
    }
  ]
}