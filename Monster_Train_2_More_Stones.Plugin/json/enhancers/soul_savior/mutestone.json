{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeMute",
      "type": "enhancer",
      "names": {
        "english": "Mutestone",
        "chinese": "静默石"
      },
      "descriptions": {
        "english": "Upgrade a spell to apply [mute] [effect0.upgrade.trigger0.effect0.status0.power] to enemy units.",
        "chinese": "升级一个法术，使其获得'对本层所有敌方单位施加[mute] [effect0.upgrade.trigger0.effect0.status0.power]。'"
      },
      "relic_effects": [
        "@SoulSavior_MuteEnhancer"
      ],
      "icon": "@SoulSavior_MutestoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassStygian",
            "pools": [
              "SoulSavior_SpellUpgradePoolCommon",
              "DraftUpgradePool",
              "MalickaDraftUpgradePool"
            ],
            "rarity": "uncommon"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_MuteEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddMuteEffect"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddMuteEffect",
      "titles": {
        "english": "Mutestone",
        "chinese": "静默石"
      },
      "descriptions": {
        "english": "Gain 'Apply [mute] [trigger0.effect0.status0.power] to enemy units.'",
        "chinese": "获得'对本层所有敌方单位施加[mute] [trigger0.effect0.status0.power]。'"
      },
      "icon": "@SoulSavior_MutestoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_ApplyMuteTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_MutestoneIcon",
      "path": "textures/mutestone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_ApplyMuteTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "Apply [mute] [effect0.status0.power] to enemy units.",
        "chinese": "对本层所有敌方单位施加[mute] [effect0.status0.power]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_EffectApplyMute"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_EffectApplyMute",
      "name": "CardEffectAddStatusEffect",
      "target_mode": "room",
      "target_team": "heroes",
      "param_status_effects": [
        {
          "status": "muted",
          "count": 1
        }
      ]
    }
  ]
}