{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_UnitUpgradeArmored",
      "type": "enhancer",
      "names": {
        "english": "Apexslab",
        "chinese": "巅峰石板"
      },
      "descriptions": {
        "english": "Upgrade a unit with '<b>Armored</b>: +[effect0.upgrade.charactertrigger0.effect0.upgrade.bonusdamage][attack].'",
        "chinese": "升级一个单位，使其获得'<b>带甲</b>：+[effect0.upgrade.charactertrigger0.effect0.upgrade.bonusdamage][attack]。'"
      },
      "relic_effects": [
        "@SoulSavior_ArmoredEnhancer"
      ],
      "icon": "@SoulSavior_ApexstoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassHellhorned",
            "pools": [
              "SoulSavior_UnitUpgradePoolRare"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_ArmoredEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "monster",
      "param_upgrade": "@SoulSavior_AddArmored"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddArmored",
      "titles": {
        "english": "Apexslab",
        "chinese": "巅峰石板"
      },
      "descriptions": {
        "english": "Gain '<b>Armored</b>: +[charactertrigger0.effect0.upgrade.bonusdamage][attack].'",
        "chinese": "获得'<b>带甲</b>：+[charactertrigger0.effect0.upgrade.bonusdamage][attack]。'"
      },
      "icon": "@SoulSavior_ApexstoneIcon",
      "trigger_upgrades": [
        {
          "id": "@SoulSavior_ArmoredAdd4AttackTrigger"
        }
      ]
    },
    {
      "id": "SoulSavior_Plus4Attack",
      "bonus_damage": 8
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_ApexstoneIcon",
      "path": "textures/apexstone.png"
    }
  ],
  "character_triggers": [
    {
      "id": "SoulSavior_ArmoredAdd4AttackTrigger",
      "trigger": "on_armor_added",
      "descriptions": {
        "english": "+[effect0.upgrade.bonusdamage][attack].",
        "chinese": "+[effect0.upgrade.bonusdamage][attack]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_EffectAdd4Attack"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_EffectAdd4Attack",
      "name": "CardEffectAddTempCardUpgradeToUnits",
      "target_mode": "self",
      "param_int": 1,
      "param_upgrade": "@SoulSavior_Plus4Attack"
    }
  ]
}