{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_UnitUpgradeHarvest",
      "type": "enhancer",
      "names": {
        "english": "Graveslab"
      },
      "descriptions": {
        "english": "Upgrade a unit with '[harvest]: +[effect0.upgrade.charactertrigger0.effect0.upgrade.bonusdamage][attack] and +[effect0.upgrade.charactertrigger0.effect0.upgrade.bonushp][health].'"
      },
      "relic_effects": [
        "@SoulSavior_HarvestEnhancer"
      ],
      "icon": "@SoulSavior_GravestoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassRemnant",
            "pools": [
              "SoulSavior_UnitUpgradePoolRare"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_HarvestEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "monster",
      "param_upgrade": "@SoulSavior_AddHarvest"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddHarvest",
      "titles": {
        "english": "Graveslab"
      },
      "descriptions": {
        "english": "Gain '[harvest]: +[charactertrigger0.effect0.upgrade.bonusdamage][attack] and +[charactertrigger0.effect0.upgrade.bonushp][health].'"
      },
      "icon": "@SoulSavior_GravestoneIcon",
      "trigger_upgrades": [
        {
          "id": "@SoulSavior_HarvestAdd2Attack2HealthTrigger"
        }
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_GravestoneIcon",
      "path": "textures/gravestone.png"
    }
  ],
  "character_triggers": [
    {
      "id": "SoulSavior_HarvestAdd2Attack2HealthTrigger",
      "trigger": "on_any_unit_death_on_floor",
      "descriptions": {
        "english": "+[effect0.upgrade.bonusdamage][attack] and +[effect0.upgrade.bonushp][health]."
      },
      "effects": [
        {
          "id": "@EffectAdd4Attack4Health"
        }
      ]
    }
  ]
}