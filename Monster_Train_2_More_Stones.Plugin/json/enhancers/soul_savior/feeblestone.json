{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "SoulSavior_SpellUpgradeSpellWeakness",
      "type": "enhancer",
      "names": {
        "english": "Feeblestone+",
        "chinese": "破魔石+"
      },
      "descriptions": {
        "english": "Upgrade a spell to apply [spellweakness] [effect0.upgrade.trigger0.effect0.status0.power] to enemy units.",
        "chinese": "升级一个法术，使其获得'对本层所有敌方单位施加[spellweakness] [effect0.upgrade.trigger0.effect0.status0.power]。'"
      },
      "relic_effects": [
        "@SoulSavior_SpellWeaknessEnhancer"
      ],
      "icon": "@SoulSavior_FeeblestoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassLunaCoven",
            "pools": [
              "SoulSavior_SpellUpgradePoolRare"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "SoulSavior_SpellWeaknessEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "spell",
      "param_upgrade": "@SoulSavior_AddSpellWeaknessEffect"
    }
  ],
  "upgrades": [
    {
      "id": "SoulSavior_AddSpellWeaknessEffect",
      "titles": {
        "english": "Feeblestone+",
        "chinese": "破魔石+"
      },
      "descriptions": {
        "english": "Gain 'Apply [spellweakness] [trigger0.effect0.status0.power] to enemy units.'",
        "chinese": "获得'对本层所有敌方单位施加[spellweakness] [trigger0.effect0.status0.power]。'"
      },
      "icon": "@SoulSavior_FeeblestoneIcon",
      "card_trigger_upgrades": [
        {
          "id": "@SoulSavior_ApplySpellWeaknessTrigger"
        }
      ],
      "filters": [
        "OnlySpells"
      ]
    }
  ],
  "sprites": [
    {
      "id": "SoulSavior_FeeblestoneIcon",
      "path": "textures/feeblestone.png"
    }
  ],
  "card_triggers": [
    {
      "id": "SoulSavior_ApplySpellWeaknessTrigger",
      "trigger": "on_cast",
      "descriptions": {
        "english": "Apply [spellweakness] [effect0.status0.power] to enemy units.",
        "chinese": "对本层所有敌方单位施加[spellweakness] [effect0.status0.power]。"
      },
      "effects": [
        {
          "id": "@SoulSavior_EffectApplySpellWeakness"
        }
      ]
    }
  ],
  "effects": [
    {
      "id": "SoulSavior_EffectApplySpellWeakness",
      "name": "CardEffectAddStatusEffect",
      "target_mode": "room",
      "target_team": "heroes",
      "param_status_effects": [
        {
          "status": "spell weakness",
          "count": 2
        }
      ]
    }
  ]
}