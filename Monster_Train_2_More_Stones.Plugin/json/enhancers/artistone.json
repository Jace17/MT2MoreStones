{
  "$schema": "https://raw.githubusercontent.com/Monster-Train-2-Modding-Group/Trainworks-Reloaded/refs/heads/main/schemas/base.json",
  "relics": [
    {
      "id": "UnitUpgradeArtificer",
      "type": "enhancer",
      "names": {
        "english": "Artistone",
        "chinese": "巧艺石"
      },
      "descriptions": {
        "english": "Upgrade a unit with '<b>Artificer</b>: +[effect0.upgrade.charactertrigger0.effect0.upgrade.bonusdamage][attack] and [armor] [effect0.upgrade.charactertrigger0.effect0.upgrade.status0.power].'",
        "chinese": "升级一个单位，使其获得'<b>巧匠</b>: +[effect0.upgrade.charactertrigger0.effect0.upgrade.bonusdamage][attack]，[armor] [effect0.upgrade.charactertrigger0.effect0.upgrade.status0.power]。'"
      },
      "relic_effects": [
        "@ArtificerEnhancer"
      ],
      "icon": "@ArtistoneIcon",
      "extensions": [
        {
          "enhancer": {
            "class": "ClassLazarusLeague",
            "pools": [
              "UnitUpgradePoolRare"
            ],
            "rarity": "rare"
          }
        }
      ]
    }
  ],
  "relic_effects": [
    {
      "id": "ArtificerEnhancer",
      "name": "RelicEffectCardUpgrade",
      "param_card_type": "monster",
      "param_upgrade": "@AddArtificer"
    }
  ],
  "upgrades": [
    {
      "id": "AddArtificer",
      "titles": {
        "english": "Artistone",
        "chinese": "巧艺石"
      },
      "descriptions": {
        "english": "Gain '<b>Artificer</b>: +[charactertrigger0.effect0.upgrade.bonusdamage][attack] and [armor] [charactertrigger0.effect0.upgrade.status0.power].'",
        "chinese": "获得'<b>巧匠</b>: +[charactertrigger0.effect0.upgrade.bonusdamage][attack]，[armor] [charactertrigger0.effect0.upgrade.status0.power]。'"
      },
      "icon": "@ArtistoneIcon",
      "trigger_upgrades": [
        {
          "id": "@ArtificerAdd8Attack8HealthTrigger"
        }
      ]
    }
  ],
  "sprites": [
    {
      "id": "ArtistoneIcon",
      "path": "textures/artistone.png"
    }
  ],
  "character_triggers": [
    {
      "id": "ArtificerAdd8Attack8HealthTrigger",
      "trigger": "on_equipment_added_to_ally",
      "descriptions": {
        "english": "+[effect0.upgrade.bonusdamage][attack] and [armor] [effect0.upgrade.status0.power].",
        "chinese": "+[effect0.upgrade.bonusdamage][attack]，[armor] [effect0.upgrade.status0.power]。"
      },
      "effects": [
        {
          "id": "@EffectAdd8Attack8Armor"
        }
      ]
    }
  ]
}